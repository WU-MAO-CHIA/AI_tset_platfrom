DATABASE_URL=sqlite+aiosqlite:///./data/autotest.db
MEDIA_ROOT=./data/media
ROBOT_SCRIPTS_DIR=./robot_scripts
PARALLEL_MAX_WORKERS=5

# LLM API Keys (set at least one)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Default LLM model（後台「目前啟用模型」未設定時的 fallback）
DEFAULT_LLM_MODEL=claude-sonnet-4-6

# 本地 Ollama 原生 API base URL（留空＝不啟用本地模型）
OLLAMA_BASE_URL=http://localhost:11434

# JWT Authentication
# 注意：JWT_SECRET_KEY 必須是固定值，否則每次重啟都會讓既有 token 失效（造成 401）
JWT_SECRET_KEY=change-me-to-a-strong-random-secret-key
# token 有效時數：168h = 7 天，避免測試人員每天重新登入觸發 401
JWT_EXPIRE_HOURS=168

# Initial admin account (used by seed_admin.py)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
