<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>執行報告 {{ execution.id }}</title>
  <style>
    body { font-family: 'Helvetica Neue', Arial, sans-serif; margin: 0; padding: 20px; background: #f5f5f5; color: #333; }
    .header { background: #2c3e50; color: white; padding: 20px; border-radius: 8px; margin-bottom: 20px; }
    .header h1 { margin: 0 0 8px; font-size: 1.5rem; }
    .summary { display: flex; gap: 16px; margin-top: 10px; }
    .badge { padding: 4px 12px; border-radius: 20px; font-size: 0.85rem; font-weight: bold; }
    .badge.pass { background: #27ae60; }
    .badge.fail { background: #e74c3c; }
    .badge.completed { background: #2980b9; }
    table { width: 100%; border-collapse: collapse; background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.1); }
    th { background: #34495e; color: white; padding: 12px 16px; text-align: left; font-size: 0.85rem; text-transform: uppercase; }
    td { padding: 12px 16px; border-bottom: 1px solid #eee; }
    tr:last-child td { border-bottom: none; }
    tr.pass td:nth-child(2) { color: #27ae60; font-weight: bold; }
    tr.fail td:nth-child(2) { color: #e74c3c; font-weight: bold; }
    .media-list { margin-top: 8px; }
    .media-list img { max-width: 120px; max-height: 80px; border: 1px solid #ddd; border-radius: 4px; margin-right: 8px; cursor: pointer; }
    .failure-msg { color: #e74c3c; font-size: 0.85rem; }
  </style>
</head>
<body>
  <div class="header">
    <h1>測試執行報告</h1>
    <p>執行 ID：{{ execution.id }}</p>
    <div class="summary">
      <span class="badge {{ execution.status }}">{{ execution.status }}</span>
      <span>通過：{{ execution.passed_count }}</span>
      <span>失敗：{{ execution.failed_count }}</span>
      <span>總計：{{ execution.total_count }}</span>
      {% if execution.elapsed_ms %}
      <span>耗時：{{ (execution.elapsed_ms / 1000) | round(1) }}s</span>
      {% endif %}
    </div>
  </div>

  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>案例名稱</th>
        <th>狀態</th>
        <th>耗時</th>
        <th>失敗訊息</th>
        <th>截圖</th>
      </tr>
    </thead>
    <tbody>
      {% for result in results %}
      <tr class="{{ 'pass' if result.status == 'passed' else 'fail' }}">
        <td>{{ loop.index }}</td>
        <td>{{ result.case_name }}</td>
        <td>{{ result.status }}</td>
        <td>{{ result.elapsed_ms }}ms</td>
        <td>
          {% if result.failure_message %}
          <span class="failure-msg">{{ result.failure_message }}</span>
          {% endif %}
        </td>
        <td>
          {% if result.media %}
          <div class="media-list">
            {% for m in result.media %}
            {% if m.media_type == 'screenshot' and m.file_path %}
            <img src="/api/v1/{{ m.file_path }}" alt="Screenshot step {{ m.step_index }}" title="{{ m.step_name }}">
            {% endif %}
            {% endfor %}
          </div>
          {% endif %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</body>
</html>
